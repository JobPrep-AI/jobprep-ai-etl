# ============================================
# dbt Profile Configuration Template
# Copy this to ~/.dbt/profiles.yml and fill in your credentials
# ============================================

jobprep_dbt:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: sfedu02-pgb87192
      user: YOUR_USERNAME
      private_key_path: ~/.ssh/snowflake_key.p8
      # OR use: authenticator: externalbrowser
      role: TRAINING_ROLE
      database: JOBPREP_DB
      warehouse: COMPUTE_WH
      schema: dbt_jobprep
      threads: 4
      client_session_keep_alive: False
